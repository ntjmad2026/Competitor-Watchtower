# ── Watchtower credentials ──────────────────────────────────────────────
# Copy this file to ".env" and fill in ONE credential. The Claude Agent SDK
# reads these from the environment automatically — the server code never
# touches the secret directly.

# LOCAL DEV / TESTING — uses your Claude subscription, NOT API credits.
# Generate once with:  claude setup-token   (interactive browser login;
# requires an active Claude Pro/Max/Team/Enterprise subscription). Paste the
# printed token here. It is inference-only and expires after ~1 year.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-REPLACE_ME

# PRODUCTION — a real API key from the Claude Console (billed usage).
# Leave this COMMENTED OUT for local testing: if it is set, it takes
# precedence over CLAUDE_CODE_OAUTH_TOKEN and your subscription token is
# ignored. Uncomment only in the deployed environment.
# ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Optional: change the local port (default 8787).
# PORT=8787
